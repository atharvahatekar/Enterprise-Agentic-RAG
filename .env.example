# Groq is used directly by the NeMo guardrail classifier.
GROQ_API_KEY=
# Optional convenience value for the provider configuration you maintain in Portkey.
GROQ_FALLBACK_API_KEY=

# Portkey routes planner and responder requests through a saved configuration.
PORTKEY_API_KEY=
PORTKEY_CONFIG_ID=pc-your-saved-config

# Embeddings and vector storage.
GEMINI_API_KEY=
QDRANT_API_KEY=
QDRANT_CLUSTER_ENDPOINT=https://your-cluster.cloud.qdrant.io:6333

# Application observability.
LOGFIRE_TOKEN=
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=enterprise-rag

# Streamlit to FastAPI connection.
BACKEND_URL=http://localhost:8000
